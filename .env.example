# Gemini API Key (Required for AI generation and LLM Vision fallback)
GEMINI_API_KEY=your_gemini_api_key_here

# Task Broker Configuration
USE_CELERY=False
REDIS_URL=redis://localhost:6379/0

# Platform Credentials (Fill in for platforms you want to auto-post to)
# IndieHackers
INDIEHACKERS_USERNAME=
INDIEHACKERS_PASSWORD=

# Contra
CONTRA_API_KEY=

# Notion (For logging backlink pipelines)
NOTION_API_KEY=
NOTION_DATABASE_ID=

# Substack
SUBSTACK_EMAIL=
SUBSTACK_PASSWORD=

# Pinterest
PINTEREST_ACCESS_TOKEN=

# Peerlist
PEERLIST_API_KEY=

# SMTP Configuration for Webmaster Outreach
OUTREACH_EMAIL_SENDER=
OUTREACH_EMAIL_PASSWORD=
OUTREACH_SMTP_SERVER=smtp.gmail.com
OUTREACH_SMTP_PORT=587
